                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 bg-white">
                                    
                    <tr class="hover:bg-slate-50/80 transition-colors group">
                        <td class="py-3 px-4 align-top">
                            <input oninput="updateTextState('associates', 1, 'ge', this)" value="GE 01" placeholder="Ex: GE 01" class="w-full font-bold text-slate-800 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none transition-colors uppercase">
                        </td>
                        <td class="py-3 px-4 align-top">
                            <input oninput="updateTextState('associates', 1, 'nome', this)" value="Farmácia Saúde" placeholder="Nome do Associado..." class="w-full font-medium text-slate-800 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none transition-colors">
                        </td>
                        <td class="py-3 px-4 align-top">
                            <textarea rows="1" oninput="updateTextState('associates', 1, 'cnpjs', this); autoResize(this)" placeholder="Cole os CNPJs aqui (um por linha)..." class="auto-resize w-full text-slate-600 font-mono text-xs bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-1 outline-none resize-none transition-colors overflow-hidden" style="height: 56px;">12.345.678/0001-90
12.345.678/0002-71</textarea>
                        </td>
                        <td class="py-3 px-4 align-top">
                            <select onchange="updateSelectAndRender('associates', 1, 'fase', this)" class="w-full text-xs font-medium p-1.5 rounded-full border cursor-pointer outline-none appearance-none text-center bg-blue-100 text-blue-700 border-blue-200">
                                <option value="Mapeamento">🔍 Mapeamento</option>
                                <option value="Implantação" selected="">⚙️ Implantação</option>
                                <option value="Em Pesquisa">🚀 Em Pesquisa</option>
