                    <tr class="hover:bg-slate-50/80 transition-colors group">
                        <td class="py-3 px-4 align-top">
                            <input oninput="updateTextState('associates', 2, 'ge', this)" value="GE 02" placeholder="Ex: GE 01" class="w-full font-bold text-slate-800 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none transition-colors uppercase">
                        </td>
                        <td class="py-3 px-4 align-top">
                            <input oninput="updateTextState('associates', 2, 'nome', this)" value="Drogaria Bem Estar" placeholder="Nome do Associado..." class="w-full font-medium text-slate-800 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none transition-colors">
                        </td>
                        <td class="py-3 px-4 align-top">
                            <textarea rows="1" oninput="updateTextState('associates', 2, 'cnpjs', this); autoResize(this)" placeholder="Cole os CNPJs aqui (um por linha)..." class="auto-resize w-full text-slate-600 font-mono text-xs bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-1 outline-none resize-none transition-colors overflow-hidden" style="height: 40px;">98.765.432/0001-10</textarea>
                        </td>
                        <td class="py-3 px-4 align-top">
                            <select onchange="updateSelectAndRender('associates', 2, 'fase', this)" class="w-full text-xs font-medium p-1.5 rounded-full border cursor-pointer outline-none appearance-none text-center bg-yellow-100 text-yellow-700 border-yellow-200">
                                <option value="Mapeamento" selected="">🔍 Mapeamento</option>
                                <option value="Implantação">⚙️ Implantação</option>
                                <option value="Em Pesquisa">🚀 Em Pesquisa</option>
                                <option value="Implantado">✅ Implantado</option>
                            </select>
                        </td>
                        <td class="py-3 px-2 align-middle text-center">
                            <button onclick="removeAssociate(2)" class="p-1.5 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded transition-all" title="Remover associado">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="trash-2" aria-hidden="true" class="lucide lucide-trash-2 w-4 h-4"><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path><path d="M3 6h18"></path><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                            </button>
                        </td>
                    </tr>
                
                                </tbody>
                            </table>
                        </div>
                        <div class="p-4 bg-slate-50 border-t border-slate-100 flex justify-center">
                            <button onclick="addAssociate()" class="flex items-center gap-2 text-sm font-semibold text-white bg-purple-600 hover:bg-purple-700 px-5 py-2.5 rounded-lg shadow-sm transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="plus" aria-hidden="true" class="lucide lucide-plus w-4 h-4"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg> Adicionar Associado
                            </button>
                        </div>
                    </div>
                </div>
            </div></div>

    <script>
        // --- STATUS DA APLICAÇÃO ---
        let activeTab = 'pautas';

        // Filtros
        let filterStatus = '';
        let filterResponsavel = '';
        let filterGE = '';

        let rules = [
            { id: 1, title: 'Objetivo Central', desc: 'Balizar a relevância relativa entre produto e categoria.' },
            { id: 2, title: 'Base de Vendas', desc: 'O produto considera as vendas dos últimos 3 meses.' }
        ];

        let actions = [
            { id: 1, category: 'Acessos', title: 'Acesso e Acompanhamento de Lojas', desc: 'Necessidade de acesso ao sistema para que os analistas consigam acompanhar e visualizar as lojas.', priority: 'Alta', responsavel: 'Mariana', status: 'Pendente' },
            { id: 2, category: 'Gestão', title: 'Estruturação do Squad SUC', desc: 'Nos estruturarmos como um squad de projeto para ter melhor acompanhamento.', priority: 'Alta', responsavel: 'Diretoria', status: 'Pendente' },
            { id: 3, category: 'Alpha 7', title: 'Impactos no PMC', desc: 'Avaliar impactos do Alpha7 no PMC (Preço Máximo ao Consumidor) dentro do pricing.', priority: 'Média', responsavel: 'Time Dados', status: 'Em Andamento' },
            { id: 4, category: 'Alpha 7', title: 'Uso de Cashback', desc: 'Avaliar possibilidade de uso de cashback na estratégia.', priority: 'Média', responsavel: 'Mariana', status: 'Pendente' },
            { id: 5, category: 'Alpha 7', title: 'Impacto na Fidelidade', desc: 'Mapear se associados que possuem fidelidade ficarão sem esta possibilidade adicional.', priority: 'Média', responsavel: 'Operações', status: 'Mapear' },
            { id: 6, category: 'Implantação', title: 'Acompanhamento de Pesquisas', desc: 'Processo de implantação e lista de pesquisa ficará sob acompanhamento da equipe.', priority: 'Média', responsavel: 'Time Pricing', status: 'Pendente' }
        ];

        let associates = [
            { id: 1, ge: 'GE 01', nome: 'Farmácia Saúde', cnpjs: '12.345.678/0001-90\n12.345.678/0002-71', fase: 'Implantação' },
            { id: 2, ge: 'GE 02', nome: 'Drogaria Bem Estar', cnpjs: '98.765.432/0001-10', fase: 'Mapeamento' }
        ];

        // --- FUNÇÕES AUXILIARES DE ESTILO ---
        const getStatusStyle = (status) => {
            switch (status) {
                case 'Em Andamento': return 'bg-blue-100 text-blue-700 border-blue-200';
                case 'Concluído': return 'bg-green-100 text-green-700 border-green-200';
                case 'Mapear': return 'bg-purple-100 text-purple-700 border-purple-200';
                default: return 'bg-slate-100 text-slate-700 border-slate-200';
            }
        };

        const getPriorityStyle = (priority) => {
            switch (priority) {
                case 'Alta': return 'text-red-600 bg-red-50 font-bold border-red-100';
                case 'Média': return 'text-amber-600 bg-amber-50 font-bold border-amber-100';
                case 'Baixa': return 'text-slate-600 bg-slate-50 font-bold border-slate-100';
                default: return 'text-slate-600 bg-slate-50 border-slate-100';
            }
        };

        const getPhaseStyle = (fase) => {
            switch (fase) {
                case 'Mapeamento': return 'bg-yellow-100 text-yellow-700 border-yellow-200';
                case 'Implantação': return 'bg-blue-100 text-blue-700 border-blue-200';
                case 'Em Pesquisa': return 'bg-purple-100 text-purple-700 border-purple-200';
                case 'Implantado': return 'bg-green-100 text-green-700 border-green-200';
                default: return 'bg-slate-100 text-slate-700 border-slate-200';
            }
        };

        const escapeHTML = (str) => str ? str.toString().replace(/"/g, '&quot;') : '';

        // --- FUNÇÕES DE LÓGICA / ATUALIZAÇÃO ---
        window.switchTab = (tab) => {
            activeTab = tab;
            render();
        };

        window.updateFilter = (field, value) => {
            if (field === 'status') filterStatus = value;
            if (field === 'responsavel') filterResponsavel = value;
            if (field === 'ge') filterGE = value;
            render();
        };

        window.updateTextState = (type, id, field, element) => {
            const value = element.value;
            if (type === 'rules') {
                const item = rules.find(r => r.id === id);
                if (item) item[field] = value;
            } else if (type === 'actions') {
                const item = actions.find(a => a.id === id);
                if (item) item[field] = value;
            } else if (type === 'associates') {
                const item = associates.find(a => a.id === id);
                if (item) item[field] = value;
            }
        };

        // Função para auto-ajustar a altura dos campos de texto
        window.autoResize = function(el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
        };

        window.updateSelectAndRender = (type, id, field, element) => {
            window.updateTextState(type, id, field, element);
            render(); // Re-renderiza para atualizar as cores imediatamente
        };

        // Adicionar / Remover Regras
        window.addRule = () => { rules.push({ id: Date.now(), title: 'Nova Premissa', desc: 'Descreva a premissa aqui...' }); render(); };
        window.removeRule = (id) => { rules = rules.filter(r => r.id !== id); render(); };

        // Adicionar / Remover Pautas
        window.addAction = () => {
            actions.push({ id: Date.now(), category: 'Nova Frente', title: 'Novo Ponto de Pauta', desc: 'Detalhes da pauta...', priority: 'Média', responsavel: 'A definir', status: 'Pendente' });
            render();
        };
        window.removeAction = (id) => { actions = actions.filter(a => a.id !== id); render(); };

        // Adicionar / Remover Associados
        window.addAssociate = () => {
            associates.push({ id: Date.now(), ge: '', nome: '', cnpjs: '', fase: 'Mapeamento' });
            render();
        };
        window.removeAssociate = (id) => { associates = associates.filter(a => a.id !== id); render(); };


        // Variáveis para guardar o foco do elemento durante o re-render
        let focusedInputId = null;
        let focusedInputSelection = null;

        // --- FUNÇÃO DE RENDERIZAÇÃO PRINCIPAL ---
        function render() {
            // Guardar o status do elemento com foco antes de reescrever o HTML
            const activeEl = document.activeElement;
            if (activeEl && activeEl.id) {
                focusedInputId = activeEl.id;
                focusedInputSelection = activeEl.selectionStart;
            } else {
                focusedInputId = null;
            }

            const root = document.getElementById('root');
            const emAnaliseCount = actions.filter(i => i.status === 'Em Andamento' || i.status === 'Mapear').length;

            let html = `
                <div class="min-h-screen p-2 md:p-4 w-full">
                    
                    <!-- Cabeçalho do Relatório -->
                    <div class="max-w-[1800px] mx-auto mb-6 bg-white rounded-2xl shadow-sm border border-slate-200 p-6 md:p-8">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                            <div>
                                <div class="flex items-center gap-3 mb-2">
                                    <div class="p-3 bg-blue-600 rounded-lg text-white">
                                        <i data-lucide="target" class="w-6 h-6"></i>
                                    </div>
                                    <h1 class="text-2xl md:text-3xl font-bold text-slate-900">
                                        Matriz de Acompanhamento: Projeto Pricing
                                    </h1>
                                </div>
                            </div>
                            <div class="flex gap-4 md:ml-0">
                                <div class="text-center px-4 py-2 bg-slate-50 rounded-lg border border-slate-100">
                                    <span class="block text-2xl font-bold text-blue-600">${actions.length}</span>
                                    <span class="text-xs text-slate-500 uppercase font-semibold">Pautas</span>
                                </div>
                                <div class="text-center px-4 py-2 bg-slate-50 rounded-lg border border-slate-100">
                                    <span class="block text-2xl font-bold text-orange-500">${emAnaliseCount}</span>
                                    <span class="text-xs text-slate-500 uppercase font-semibold">Em Análise</span>
                                </div>
                                <div class="text-center px-4 py-2 bg-slate-50 rounded-lg border border-slate-100 hidden md:block">
                                    <span class="block text-2xl font-bold text-purple-600">${associates.length}</span>
                                    <span class="text-xs text-slate-500 uppercase font-semibold">Lojas Piloto</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Abas de Navegação -->
                    <div class="max-w-[1800px] mx-auto mb-6 flex gap-4 border-b border-slate-200 px-2">
                        <button onclick="switchTab('pautas')" class="pb-3 flex items-center gap-2 font-semibold text-sm transition-colors border-b-2 ${activeTab === 'pautas' ? 'border-blue-600 text-blue-600' : 'border-transparent text-slate-500 hover:text-slate-800'}">
                            <i data-lucide="layout-list" class="w-5 h-5"></i>
                            Pautas & Premissas
                        </button>
                        <button onclick="switchTab('piloto')" class="pb-3 flex items-center gap-2 font-semibold text-sm transition-colors border-b-2 ${activeTab === 'piloto' ? 'border-purple-600 text-purple-600' : 'border-transparent text-slate-500 hover:text-slate-800'}">
                            <i data-lucide="store" class="w-5 h-5"></i>
                            Lojas Piloto
                        </button>
                    </div>
            `;

            if (activeTab === 'pautas') {
                html += renderPautasView();
            } else {
                html += renderPilotoView();
            }

            html += `</div>`; // Fechar min-h-screen
            root.innerHTML = html;

            // Renderizar ícones do Lucide
            lucide.createIcons();

            // Ajustar a altura dos textareas automaticamente ao renderizar a tela
            setTimeout(() => {
                document.querySelectorAll('.auto-resize').forEach(el => window.autoResize(el));
            }, 0);

            // Devolver o foco ao campo se o utilizador estiver a escrever nos filtros
            if (focusedInputId) {
                const el = document.getElementById(focusedInputId);
                if (el) {
                    el.focus();
                    try { el.setSelectionRange(focusedInputSelection, focusedInputSelection); } catch(e){}
                }
            }
        }

        function renderPautasView() {
            let rulesHtml = rules.map(rule => `
                <div class="p-3 bg-blue-50/50 rounded-xl border border-blue-100 relative group">
                    <button onclick="removeRule(${rule.id})" class="absolute top-2 right-2 p-1 text-slate-400 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity" title="Remover premissa">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                    <textarea rows="1" oninput="updateTextState('rules', ${rule.id}, 'title', this); autoResize(this)" class="auto-resize font-semibold text-blue-900 text-sm mb-1 w-full bg-transparent border-b border-transparent hover:border-blue-300 focus:border-blue-500 focus:bg-white outline-none px-1 rounded transition-colors resize-none overflow-hidden">${escapeHTML(rule.title)}</textarea>
                    <textarea rows="1" oninput="updateTextState('rules', ${rule.id}, 'desc', this); autoResize(this)" class="auto-resize text-sm text-blue-800/80 leading-relaxed w-full bg-transparent border border-transparent hover:border-blue-300 focus:border-blue-500 focus:bg-white outline-none resize-none px-1 rounded transition-colors overflow-hidden">${escapeHTML(rule.desc)}</textarea>
                </div>
            `).join('');

            // Aplicar filtros nas Pautas
            let filteredActions = actions.filter(item => {
                const matchStatus = filterStatus === '' || item.status === filterStatus;
                const matchResponsavel = filterResponsavel === '' || item.responsavel.toLowerCase().includes(filterResponsavel.toLowerCase());
                return matchStatus && matchResponsavel;
            });

            let actionsHtml = '';
            
            if (filteredActions.length > 0) {
                actionsHtml = filteredActions.map(item => `
                    <tr class="hover:bg-slate-50/80 transition-colors group">
                        <td class="py-3 px-4 align-top">
                            <textarea rows="1" oninput="updateTextState('actions', ${item.id}, 'title', this); autoResize(this)" class="auto-resize w-full font-bold text-slate-800 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none transition-colors resize-none overflow-hidden">${escapeHTML(item.title)}</textarea>
                        </td>
                        <td class="py-3 px-4 align-top">
                            <textarea rows="1" oninput="updateTextState('actions', ${item.id}, 'desc', this); autoResize(this)" class="auto-resize w-full text-slate-600 text-sm bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none resize-none transition-colors overflow-hidden">${escapeHTML(item.desc)}</textarea>
                        </td>
                        <td class="py-3 px-4 align-top">
                            <select onchange="updateSelectAndRender('actions', ${item.id}, 'priority', this)" class="w-full text-xs p-1.5 rounded outline-none border cursor-pointer appearance-none text-center ${getPriorityStyle(item.priority)}">
                                <option value="Alta" ${item.priority === 'Alta' ? 'selected' : ''}>Alta</option>
                                <option value="Média" ${item.priority === 'Média' ? 'selected' : ''}>Média</option>
                                <option value="Baixa" ${item.priority === 'Baixa' ? 'selected' : ''}>Baixa</option>
                            </select>
                        </td>
                        <td class="py-3 px-4 align-top">
                            <input oninput="updateTextState('actions', ${item.id}, 'responsavel', this)" value="${escapeHTML(item.responsavel)}" placeholder="Nome..." class="w-full text-sm font-medium text-slate-700 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-2 py-1 outline-none transition-colors" />
                        </td>
                        <td class="py-3 px-4 align-top">
                            <select onchange="updateSelectAndRender('actions', ${item.id}, 'status', this)" class="w-full text-xs font-medium p-1.5 rounded-full border cursor-pointer outline-none appearance-none text-center ${getStatusStyle(item.status)}">
                                <option value="Pendente" ${item.status === 'Pendente' ? 'selected' : ''}>⏳ Pendente</option>
                                <option value="Mapear" ${item.status === 'Mapear' ? 'selected' : ''}>🔍 Mapear</option>
                                <option value="Em Andamento" ${item.status === 'Em Andamento' ? 'selected' : ''}>🚧 Em Andamento</option>
                                <option value="Concluído" ${item.status === 'Concluído' ? 'selected' : ''}>✅ Concluído</option>
                            </select>
                        </td>
                        <td class="py-3 px-2 align-middle text-center">
                            <button onclick="removeAction(${item.id})" class="p-1.5 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded transition-all" title="Remover pauta">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } else {
                actionsHtml = `<tr><td colspan="6" class="py-12 text-center text-slate-500 font-medium">Nenhuma pauta encontrada com os filtros aplicados.</td></tr>`;
            }

            return `
                <div class="max-w-[1800px] mx-auto grid grid-cols-1 xl:grid-cols-4 gap-6">
                    <!-- Coluna Lateral: Regras -->
                    <div class="xl:col-span-1 space-y-6">
                        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5">
                            <div class="flex justify-between items-center mb-4">
                                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider flex items-center gap-2">
                                    <i data-lucide="book-open" class="w-4 h-4"></i>
                                    Premissas do Projeto
                                </h2>
                            </div>
                            <div class="space-y-4">
                                ${rulesHtml}
                                <button onclick="addRule()" class="w-full py-2 flex items-center justify-center gap-2 text-sm font-semibold text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg border border-blue-200 transition-colors">
                                    <i data-lucide="plus" class="w-4 h-4"></i> Adicionar Premissa
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Coluna Principal: Tabela -->
                    <div class="xl:col-span-3">
                        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                            
                            <!-- Barra de Título e Filtros -->
                            <div class="border-b border-slate-100 p-5 flex flex-col md:flex-row justify-between items-start md:items-center bg-slate-50/50 gap-4">
                                <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                                    <i data-lucide="file-text" class="w-5 h-5 text-blue-600"></i>
                                    Plano de Ação / Pautas em Aberto
                                </h2>
                                
                                <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                                    <div class="flex items-center bg-white border border-slate-200 rounded-lg px-2 shadow-sm focus-within:border-blue-500 transition-colors">
                                        <i data-lucide="filter" class="w-4 h-4 text-slate-400"></i>
                                        <select id="filterStatus" onchange="updateFilter('status', this.value)" class="text-sm bg-transparent border-none outline-none py-2 pl-2 text-slate-600 cursor-pointer w-full sm:w-auto">
                                            <option value="">Todos os Status</option>
                                            <option value="Pendente" ${filterStatus === 'Pendente' ? 'selected' : ''}>Pendente</option>
                                            <option value="Mapear" ${filterStatus === 'Mapear' ? 'selected' : ''}>Mapear</option>
                                            <option value="Em Andamento" ${filterStatus === 'Em Andamento' ? 'selected' : ''}>Em Andamento</option>
                                            <option value="Concluído" ${filterStatus === 'Concluído' ? 'selected' : ''}>Concluído</option>
                                        </select>
                                    </div>
                                    <div class="flex items-center bg-white border border-slate-200 rounded-lg px-3 shadow-sm focus-within:border-blue-500 transition-colors">
                                        <i data-lucide="search" class="w-4 h-4 text-slate-400"></i>
                                        <input id="filterResponsavel" type="text" oninput="updateFilter('responsavel', this.value)" value="${escapeHTML(filterResponsavel)}" placeholder="Filtrar responsável..." class="text-sm bg-transparent border-none outline-none py-2 pl-2 w-full sm:w-40 text-slate-600 placeholder-slate-400" />
                                    </div>
                                </div>
                            </div>

                            <div class="overflow-x-auto">
                                <table class="w-full text-left text-sm min-w-[900px]">
                                    <thead class="bg-white border-b border-slate-100 text-slate-500">
                                        <tr>
                                            <th class="py-4 px-4 font-semibold w-64">Frente / Tópico</th>
                                            <th class="py-4 px-4 font-semibold">Ação</th>
                                            <th class="py-4 px-4 font-semibold w-32">Prioridade</th>
                                            <th class="py-4 px-4 font-semibold w-40">Responsável</th>
                                            <th class="py-4 px-4 font-semibold w-40">Status</th>
                                            <th class="py-4 px-2 font-semibold w-12 text-center"></th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 bg-white">
                                        ${actionsHtml}
                                    </tbody>
                                </table>
                            </div>
                            <div class="p-4 bg-slate-50 border-t border-slate-100 flex justify-center">
                                <button onclick="addAction()" class="flex items-center gap-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 px-5 py-2.5 rounded-lg shadow-sm transition-colors">
                                    <i data-lucide="plus" class="w-4 h-4"></i> Adicionar Pauta em Aberto
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function renderPilotoView() {
            // Aplicar Filtro no G.E
            let filteredAssociates = associates.filter(item => {
                return filterGE === '' || item.ge.toLowerCase().includes(filterGE.toLowerCase());
            });

            let associatesHtml = '';

            if (filteredAssociates.length > 0) {
                associatesHtml = filteredAssociates.map(item => `
                    <tr class="hover:bg-slate-50/80 transition-colors group">
                        <td class="py-3 px-4 align-top">
                            <input oninput="updateTextState('associates', ${item.id}, 'ge', this)" value="${escapeHTML(item.ge)}" placeholder="Ex: GE 01" class="w-full font-bold text-slate-800 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none transition-colors uppercase" />
                        </td>
                        <td class="py-3 px-4 align-top">
                            <input oninput="updateTextState('associates', ${item.id}, 'nome', this)" value="${escapeHTML(item.nome)}" placeholder="Nome do Associado..." class="w-full font-medium text-slate-800 bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-0.5 outline-none transition-colors" />
                        </td>
                        <td class="py-3 px-4 align-top">
                            <textarea rows="1" oninput="updateTextState('associates', ${item.id}, 'cnpjs', this); autoResize(this)" placeholder="Cole os CNPJs aqui (um por linha)..." class="auto-resize w-full text-slate-600 font-mono text-xs bg-transparent border border-transparent hover:border-slate-300 focus:bg-white focus:border-blue-500 rounded px-1 py-1 outline-none resize-none transition-colors overflow-hidden">${escapeHTML(item.cnpjs)}</textarea>
                        </td>
                        <td class="py-3 px-4 align-top">
                            <select onchange="updateSelectAndRender('associates', ${item.id}, 'fase', this)" class="w-full text-xs font-medium p-1.5 rounded-full border cursor-pointer outline-none appearance-none text-center ${getPhaseStyle(item.fase)}">
                                <option value="Mapeamento" ${item.fase === 'Mapeamento' ? 'selected' : ''}>🔍 Mapeamento</option>
                                <option value="Implantação" ${item.fase === 'Implantação' ? 'selected' : ''}>⚙️ Implantação</option>
                                <option value="Em Pesquisa" ${item.fase === 'Em Pesquisa' ? 'selected' : ''}>🚀 Em Pesquisa</option>
                                <option value="Implantado" ${item.fase === 'Implantado' ? 'selected' : ''}>✅ Implantado</option>
                            </select>
                        </td>
                        <td class="py-3 px-2 align-middle text-center">
                            <button onclick="removeAssociate(${item.id})" class="p-1.5 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded transition-all" title="Remover associado">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } else {
                associatesHtml = `<tr><td colspan="5" class="py-12 text-center text-slate-500 font-medium">Nenhum associado encontrado para este G.E.</td></tr>`;
            }

            return `
                <div class="max-w-[1800px] mx-auto">
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        
                        <!-- Barra de Título e Filtros -->
                        <div class="border-b border-slate-100 p-5 flex flex-col md:flex-row justify-between items-start md:items-center bg-slate-50/50 gap-4">
                            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                                <i data-lucide="store" class="w-5 h-5 text-purple-600"></i>
                                Lojas Participantes do Projeto
                            </h2>
                            
                            <div class="flex items-center bg-white border border-slate-200 rounded-lg px-3 shadow-sm focus-within:border-blue-500 transition-colors w-full md:w-auto">
                                <i data-lucide="search" class="w-4 h-4 text-slate-400"></i>
                                <input id="filterGE" type="text" oninput="updateFilter('ge', this.value)" value="${escapeHTML(filterGE)}" placeholder="Filtrar por G.E..." class="text-sm bg-transparent border-none outline-none py-2 pl-2 w-full sm:w-48 text-slate-600 placeholder-slate-400" />
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm min-w-[900px]">
                                <thead class="bg-white border-b border-slate-100 text-slate-500">
                                    <tr>
                                        <th class="py-4 px-4 font-semibold w-32">G.E</th>
                                        <th class="py-4 px-4 font-semibold w-64">Associado</th>
                                        <th class="py-4 px-4 font-semibold">Lista de CNPJs</th>
                                        <th class="py-4 px-4 font-semibold w-48">Fase Atual</th>
                                        <th class="py-4 px-2 font-semibold w-12 text-center">Ações</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 bg-white">
                                    ${associatesHtml}
                                </tbody>
                            </table>
                        </div>
                        <div class="p-4 bg-slate-50 border-t border-slate-100 flex justify-center">
                            <button onclick="addAssociate()" class="flex items-center gap-2 text-sm font-semibold text-white bg-purple-600 hover:bg-purple-700 px-5 py-2.5 rounded-lg shadow-sm transition-colors">
                                <i data-lucide="plus" class="w-4 h-4"></i> Adicionar Associado
                            </button>
                        </div>
                    </div>
                </div>
            `;
        }

        // --- INICIALIZAÇÃO ---
        render();

    </script>

</body>
